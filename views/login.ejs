<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

<h1>Login</h1>

<form action="/login" method="POST">

  <input
    type="email"
    name="email"
    placeholder="Email"
  >

  <input
    type="password"
    name="password"
    placeholder="Password"
  >

  <button>Login</button>

</form>

<a href="/register">
  Register
</a>

</body>
</html>